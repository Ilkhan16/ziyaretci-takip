PORT=3000
BASE_URL=http://localhost:3000

# JWT auth secret — guclu rastgele bir string girin (en az 32 karakter)
JWT_SECRET=change-this-to-a-long-random-secret-string

# MongoDB Atlas baglanti dizisi
# Atlas'ta ucretsiz M0 cluster olusturun: https://cloud.mongodb.com
# Ornek: mongodb+srv://kullanici:sifre@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://kullanici:sifre@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=ziyaretci_takip

# Ilk admin kullanicisi (seed.js icin)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=guclu-sifre-buraya
SEED_ADMIN_FULL_NAME=Admin

# Mail gonderimi (SMTP — Gmail ile calisir)
# Gmail: Uygulama sifresi olusturun (2FA aktifken)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Mail Webhook (alternatif — Google Apps Script ile)
# Kurulum: google-apps-script.js dosyasina bak
MAIL_WEBHOOK_URL=
