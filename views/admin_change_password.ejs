<%- include('partials/layout_top', { title }) %>
<%- include('partials/admin_nav', { admin }) %>

<div class="card card-center animate-in">
  <div class="text-center" style="margin-bottom:24px">
    <div style="width:56px;height:56px;border-radius:50%;background:var(--primary-glow);border:2px solid rgba(59,130,246,.3);display:flex;align-items:center;justify-content:center;font-size:24px;margin:0 auto 16px">🔒</div>
    <h1 class="h1" style="margin-bottom:4px">Şifre Değiştir</h1>
    <p class="p">Hesap güvenliğiniz için şifrenizi düzenli olarak değiştirin</p>
  </div>

  <% if (error) { %>
    <div class="alert alert-danger">
      <span class="alert-icon">⚠️</span>
      <div class="alert-body"><%= error %></div>
    </div>
  <% } %>

  <% if (success) { %>
    <div class="alert alert-success">
      <span class="alert-icon">✅</span>
      <div class="alert-body"><%= success %></div>
    </div>
  <% } %>

  <form method="POST" action="/admin/change-password" class="form">
    <div class="form-group">
      <label class="label">Mevcut Şifre</label>
      <input type="password" name="current_password" class="input" required placeholder="Mevcut şifrenizi girin">
    </div>

    <hr class="hr">

    <div class="form-group">
      <label class="label">Yeni Şifre</label>
      <input type="password" name="new_password" class="input" required minlength="6" placeholder="En az 6 karakter">
    </div>

    <div class="form-group">
      <label class="label">Yeni Şifre (Tekrar)</label>
      <input type="password" name="confirm_password" class="input" required minlength="6" placeholder="Yeni şifrenizi tekrar girin">
    </div>

    <button type="submit" class="btn primary btn-block">Şifreyi Güncelle</button>
  </form>
</div>

<%- include('partials/layout_bottom') %>
